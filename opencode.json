{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "read-website-fast": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "--package",
        "ajv",
        "--package",
        "@just-every/mcp-read-website-fast",
        "mcp-read-website-fast"
      ]
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    }
  },
  "provider": {
    "neuralwatt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Neuralwatt",
      "options": {
        "baseURL": "https://api.neuralwatt.com/v1",
        "name": "neuralwatt"
      },
      "whitelist": [
        "zai-org/GLM-5.1-FP8",
        "moonshotai/Kimi-K2.6"
      ],
      "models": {
        "zai-org/GLM-5.1-FP8": {
          "name": "GLM 5.1",
          "limit": {
            "context": 200000,
            "output": 131072
          }
        },
        "moonshotai/Kimi-K2.6": {
          "name": "Kimi K2.6",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        }
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com/v1",
        "name": "deepseek"
      },
      "whitelist": [
        "deepseek-v4-pro",
        "deepseek-v4-flash"
      ],
      "models": {
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro",
          "limit": {
            "context": 1048576,
            "output": 384000
          }
        },
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "limit": {
            "context": 1048576,
            "output": 384000
          }
        }
      }
    },
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "name": "opencode-go"
      },
      "whitelist": [
        "glm-5.1",
        "kimi-k2.6",
        "deepseek-v4-pro"
      ],
      "models": {
        "glm-5.1": {
          "name": "glm-5.1",
          "limit": {
            "context": 200000,
            "output": 131072
          }
        },
        "kimi-k2.6": {
          "name": "kimi-k2.6",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "deepseek-v4-pro": {
          "name": "deepseek-v4-pro",
          "limit": {
            "context": 1048576,
            "output": 384000
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    },
    "general": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    },
    "plan": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    },
    "explore": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    },
    "scout": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    },
    "title": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    },
    "summary": {
      "model": "neuralwatt/zai-org/GLM-5.1-FP8"
    }
  }
}
